{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Taiwan Menopause Weight Guide Schema",
  "definitions": {
    "HormonalChange": {
      "type": "object",
      "required": ["id", "hormone", "change_type", "source"],
      "properties": {
        "id": { "type": "string" },
        "hormone": { "type": "string" },
        "change_type": { "type": "string", "enum": ["decline", "increase", "relative_increase", "fluctuate"] },
        "weight_impact": { "type": "object" },
        "source": { "type": "string" }
      }
    },
    "DietStrategy": {
      "type": "object",
      "required": ["id", "strategy_zh", "priority", "evidence_grade", "source"],
      "properties": {
        "id": { "type": "string" },
        "strategy_zh": { "type": "string" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "evidence_grade": { "type": "string", "enum": ["A", "B", "C"] },
        "recommendation_zh": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "SymptomNutrition": {
      "type": "object",
      "required": ["id", "symptom_zh", "source"],
      "properties": {
        "id": { "type": "string" },
        "symptom_zh": { "type": "string" },
        "trigger_foods_zh": { "type": "array", "items": { "type": "string" } },
        "helpful_foods_zh": { "type": "array", "items": { "type": "string" } },
        "source": { "type": "string" }
      }
    }
  }
}
